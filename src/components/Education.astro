---
interface Props {
    Estudio: string;
    Institucion: string;
    fecha: string;
}

const { Estudio, Institucion, fecha} = Astro.props;
---

<li class="xl:w-auto md:w-1/2 p-2">
    <div class="border border-gray-700 p-6 rounded-lg">
      <h2 class="text-lg text-gray-900 font-medium title-font mb-2">{Estudio}</h2>
      <p class="text-sky-500/90 mb-2">{Institucion}</p>
      <p>{fecha}</p>
    </div>
</li>